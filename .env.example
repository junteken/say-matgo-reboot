# Environment Variables Template
# Copy this file to .env.local for local development

# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================

# WebSocket Server URL (required)
# Local development: http://localhost:8080
# Production: Railway deployment URL
NEXT_PUBLIC_WEBSOCKET_URL=http://localhost:8080

# ============================================
# BACKEND ENVIRONMENT VARIABLES (Railway)
# ============================================

# Server Configuration
PORT=8080
NODE_ENV=production

# Client URL for CORS
# Local development: http://localhost:3000
# Production: Vercel deployment URL
CLIENT_URL=http://localhost:3000

# ============================================
# SUPABASE CONFIGURATION (optional)
# ============================================

# Supabase URL
SUPABASE_URL=your-supabase-url

# Supabase Anonymous Key
SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase JWKS URL for JWT verification
SUPABASE_JWKS_URL=https://your-project.supabase.co/.well-known/jwks.json

# ============================================
# REDIS CONFIGURATION (optional - for scaling)
# ============================================

# Redis URL for Socket.IO Redis adapter
# Format: redis://username:password@host:port
REDIS_URL=redis://localhost:6379

# Redis TLS (optional)
REDIS_TLS=false

# ============================================
# LOGGING CONFIGURATION
# ============================================

# Log level: error, warn, info, debug
LOG_LEVEL=info

# Enable structured logging
STRUCTURED_LOGGING=true
