{
  "name": "say-matgo-reboot",
  "version": "0.1.0",
  "description": "Say Mat-go Reboot - Modern Korean Card Game",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:ws": "tsx watch src/server/index.ts",
    "build": "next build",
