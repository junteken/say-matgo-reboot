# @MX:NOTE: Environment variables for Railway WebSocket server deployment
# Copy this file to .railway/env and set actual values in Railway dashboard

# @MX:ANCHOR: Authentication configuration - JWT validation (FR-AU-001, FR-AU-002, UR-001)
# Supabase JWKS endpoint for JWT token validation
SUPABASE_JWKS_URL=https://[your-project].supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_PROJECT_ID=your-project-id

# @MX:NOTE: Secret for JWT validation (if using custom JWT)
# For Supabase, this is optional as JWKS is used
JWT_SECRET=your-jwt-secret-here

# @MX:ANCHOR: Redis configuration for horizontal scaling (NFR-S-001)
# Redis Pub/Sub for cross-instance state synchronization
REDIS_URL=redis://default:[password]@[host]:[port]
REDIS_ENABLED=true

# @MX:NOTE: Server configuration
# Railway provides PORT automatically, but can be overridden locally
PORT=8080
NODE_ENV=production

# @MX:NOTE: WebSocket configuration
# Heartbeat interval for connection monitoring (FR-CM-004)
HEARTBEAT_INTERVAL=10000

# Reconnection timeout in milliseconds (NFR-R-001)
RECONNECTION_TIMEOUT=30000

# @MX:NOTE: Rate limiting configuration (NFR-SEC-002)
# Requests per minute per client
RATE_LIMIT_MAX=100

# @MX:NOTE: Room cleanup configuration
# Empty room auto-delete delay in milliseconds (FR-RM-005)
ROOM_CLEANUP_DELAY=30000

# @MX:NOTE: CORS configuration
# Client domain for WebSocket connections
CLIENT_URL=https://your-frontend-domain.vercel.app
